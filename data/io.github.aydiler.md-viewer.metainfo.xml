<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.aydiler.md-viewer</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <name>Markdown Viewer</name>
  <summary>Fast, lightweight markdown viewer for Linux</summary>

  <description>
    <p>
      A fast, lightweight markdown viewer built with Rust and egui.
      Designed for distraction-free reading with excellent typography
      and syntax highlighting.
    </p>
    <p>Features:</p>
    <ul>
      <li>GitHub Flavored Markdown with syntax highlighting (200+ languages)</li>
      <li>Tab system for multiple documents</li>
      <li>File explorer sidebar</li>
      <li>Outline / table-of-contents sidebar</li>
      <li>Dark and light themes</li>
      <li>Live reload on file changes</li>
      <li>Session persistence</li>
      <li>Native X11 and Wayland support</li>
      <li>Mermaid diagrams, math, and image rendering</li>
    </ul>
  </description>

  <launchable type="desktop-id">io.github.aydiler.md-viewer.desktop</launchable>

  <url type="homepage">https://github.com/aydiler/md-viewer</url>
  <url type="bugtracker">https://github.com/aydiler/md-viewer/issues</url>
  <url type="vcs-browser">https://github.com/aydiler/md-viewer</url>

  <developer id="io.github.aydiler">
    <name>aydiler</name>
  </developer>

